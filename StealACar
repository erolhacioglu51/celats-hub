-- Fonksiyon: Toggle butonu yarat
local function createToggle(name, parent, default, callback)
    local TFrame = Instance.new("Frame")
    TFrame.Size = UDim2.new(1, -20, 0, 30)
    TFrame.Position = UDim2.new(0, 10, 0, 0)
    TFrame.BackgroundTransparency = 1
    TFrame.Parent = parent

    local label = Instance.new("TextLabel")
    label.Text = name
    label.Size = UDim2.new(0.7, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.fromRGB(255,255,255)
    label.Font = Enum.Font.Gotham
    label.TextSize = 16
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = TFrame

    local toggle = Instance.new("TextButton")
    toggle.Size = UDim2.new(0, 50, 0, 25)
    toggle.Position = UDim2.new(0.75, 0, 0, 2)
    toggle.BackgroundColor3 = default and Color3.fromRGB(0, 180, 0) or Color3.fromRGB(180, 0, 0)
    toggle.Text = default and "Açık" or "Kapalı"
    toggle.TextColor3 = Color3.fromRGB(255,255,255)
    toggle.Font = Enum.Font.GothamBold
    toggle.TextSize = 14
    toggle.Parent = TFrame

    toggle.MouseButton1Click:Connect(function()
        default = not default
        toggle.BackgroundColor3 = default and Color3.fromRGB(0, 180, 0) or Color3.fromRGB(180, 0, 0)
        toggle.Text = default and "Açık" or "Kapalı"
        if callback then callback(default) end
    end)

    return TFrame, toggle
end

