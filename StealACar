-- Auto Steal (En Yakın Arabayı Çal)
local autoStealConnection
createToggle("🚘 Otomatik Araba Çal", FeaturesFrame, false, function(enabled)
    autoStealEnabled = enabled
    if enabled then
        autoStealConnection = RunService.Heartbeat:Connect(function()
            local nearestCar
            local minDist = math.huge
            for _,veh in pairs(workspace:GetDescendants()) do
                if veh:IsA("VehicleSeat") then
                    local dist = (veh.Position - root.Position).Magnitude
                    if dist < minDist then
                        minDist = dist
                        nearestCar = veh
                    end
                end
            end
            if nearestCar and minDist < 50 then
                -- Aracın içine ışınlanma (koltuk)
                local driverSeat = nearestCar
                if driverSeat and driverSeat:IsA("VehicleSeat") then
                    root.CFrame = driverSeat.CFrame + Vector3.new(0,3,0)
                end
            end
        end)
    else
        if autoStealConnection then
            autoStealConnection:Disconnect()
            autoStealConnection = nil
        end
    end
end)

-- Otomatik Lazer Yenileme (Güvenlik Düğmesi)
createToggle("🔁 Otomatik Lazer Yenile", FeaturesFrame, false, function(enabled)
