                        fireproximityprompt(v)
                        print("✅ Otomatik lazer yenilendi (ProximityPrompt)")
                        break
                    elseif v:IsA("ClickDetector") and v.Parent.Name:lower():find("button") then
                        fireclickdetector(v)
                        print("✅ Otomatik lazer yenilendi (ClickDetector)")
                        break
                    elseif v:IsA("Part") and v.Name:lower():find("button") then
                        firetouchinterest(root, v, 0)
                        wait(0.1)
                        firetouchinterest(root, v, 1)
                        print("✅ Otomatik lazer yenilendi (TouchPart)")
                        break
                    end
                end
            end
        end)()
    end
end)

-- ESP (Araçları yeşil kutu ile gösterme)
local espEnabled = false
local espBoxes = {}

createToggle("👁️ ESP (Araçlar)", FeaturesFrame, false, function(enabled)
    espEnabled = enabled
    if espEnabled then
        for _,obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("VehicleSeat") then
                if not espBoxes[obj] then
                    local box = Instance.new("BoxHandleAdornment")
                    box.Size = Vector3.new(6,4,12)
                    box.Adornee = obj
                    box.Color3 = Color3.fromRGB(0,255,0)
                    box.Transparency = 0.4
                    box.AlwaysOnTop = true
                    box.Parent = obj
                    espBoxes[obj] = box
                end
            end
        end
    else
        for obj,box in pairs(espBoxes) do
            if box then box:Destroy() end
        end
        espBoxes = {}
    end
end)

